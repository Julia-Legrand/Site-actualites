{% extends 'base.html.twig' %}

{% block title %}Espace Rédacteurs{% endblock %}

{% block body %}
	{% include "_partials/_headerLogin.html.twig" %}
	<main class="redacAdmin">
		<section class="row mr-3 ml-0">
			{% include "_partials/_sidebarRedac.html.twig" %}

			<div class="col-md-10" id="dashboard" style="padding:10px 40px;">
				<h2>Mes articles</h2>
				<table class="table">
					<thead>
						<tr>
							<th>Catégorie</th>
							<th>Illustration</th>
							<th>Titre</th>
							<th>Auteur</th>
							<th>Date</th>
                            <th>Modifier</th>
						</tr>
					</thead>
					<tbody>
						{% for article in articles %}
							<tr>
								<td>{{ article.category.nameCategory }}</td>
								<td><img src="{{ asset('uploads/images/' ~ article.picture) }}" width="100"></td>
								<td>{{ article.title }}</td>
								<td>{{ article.user.firstName ~ ' ' ~ article.user.lastName }}</td>
								<td>{{ article.createdAt ? article.createdAt|date('d-m-Y') : '' }}</td>
                                <td style="display:flex; justify-content:center; align-items:center;">
									<a href="{{ path('app_articles_edit', {'id': article.id}) }}" style="margin-right:5px;;"><i class="fa-solid fa-pen" style="margin:0;"></i></a>
                                    {{ include('articles/_delete_form.html.twig') }}
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</section>
	</main>
{% endblock %}
